{
  "name": "@blitheforge/media-library",
  "version": "1.1.1",
  "description": "Self-contained React media library with pre-built CSS. Works with or without Tailwind in your app.",
  "license": "MIT",
  "author": "Mahadi Hasan",
  "email": "mehedibuet11@gmail.com",
  "keywords": [
    "react",
    "media-library",
    "file-upload",
    "folder",
    "image-picker",
    "vanilla-js",
    "headless"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blitheforge/Media-Library.git"
  },
  "bugs": {
    "url": "https://github.com/blitheforge/Media-Library/issues"
  },
  "homepage": "https://github.com/blitheforge/Media-Library#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./styles.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup && node ./scripts/build-css.mjs",
    "build:js": "tsup",
    "build:css": "node ./scripts/build-css.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.561.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.6",
    "postcss-prefixwrap": "^1.57.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
